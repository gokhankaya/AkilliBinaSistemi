<UserControl x:Class="GUI_Simulation.LCS.AddPersonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GUI_Simulation.LCS"
             mc:Ignorable="d" 
              Height="150" Width="315" Background="WhiteSmoke" BorderThickness="0.5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Label Content="{Binding ID}" FontSize="8" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="5"></Label>

        <Label Margin="2" Grid.Column="0" Grid.Row="1" Grid.RowSpan="2" VerticalContentAlignment="Top" Content="{Binding order}"></Label>
        <Label Grid.Column="1" Grid.Row="1" Content="Kişi Tanımı:" />
        <TextBox Margin="2" Grid.Column="3" Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding person}" VerticalContentAlignment="Center"/>
        <Button Margin="2" Content="X" Width="30" HorizontalAlignment="Right" Name="btnClose" Click="btnClose_Click" Grid.Column="6" Grid.Row="0" Grid.RowSpan="2" Height="25" VerticalAlignment="Top" VerticalContentAlignment="Center"/>
        <Label Content="Çizelge:" Grid.Column="1" Grid.Row="2"/>
        <ComboBox Margin="2" Name="cmbGraphs" Grid.Column="2" Grid.Row="2" Grid.ColumnSpan="2"></ComboBox>
        <Button Margin="2" Grid.Column="4" Width="60" Grid.Row="2" Content="Yükle" Name="btnLoadGraph" Click="btnLoadGraph_Click"/>
        <Button Margin="2" Grid.Column="5" Width="60" Grid.Row="2"  Content="Seç" Name="btnSelectGraph" Click="btnSelectGraph_Click"/>
        <Label Content="Sensor Sayısı:" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3"></Label>
        <Label Content="{Binding DeviceCount}" Grid.Column="3"  Grid.Row="3" HorizontalAlignment="Left"/>
        <CheckBox Content="Aile Bireyi" Grid.Column="4" Grid.ColumnSpan="2" Grid.Row="3"  HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding familyMember}" Margin="27,10,29,3"/>
        <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="6" Margin="2,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"></ColumnDefinition>
                <ColumnDefinition Width="3*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
                <ColumnDefinition Width="3*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Başlangıç: " HorizontalAlignment="Right"></Label>
            <Label Grid.Column="2" Content="Bitiş: " HorizontalAlignment="Right"></Label>
            <ComboBox x:Name="cmbFirstNode" Grid.Column="1" VerticalContentAlignment="Center"></ComboBox>
            <ComboBox x:Name="cmbLastNode" Grid.Column="3" VerticalContentAlignment="Center"></ComboBox>
        </Grid>


        <StackPanel Grid.Column="0" Grid.ColumnSpan="20" Grid.Row="5"  Orientation="Horizontal" Margin="5,0">
            <Button Name="btnsensors"  Width="60" Content="Sensörler" Margin="2" Click="btnsensors_Click"></Button>
            <Button Name="btnScnarios"  Width="60" Content="Senaryolar" Margin="2" Click="btnScenarios_Click"></Button>
            <Button Name="btnTest"  Width="60" Content="Test Et" Margin="2" Click="btnTest_Click"></Button>
            <Button Name="btnShowGraph"  Width="100" Content="Çizelgeyi Göster" Margin="2" Click="btnShowGraph_Click"></Button>
        </StackPanel>

    </Grid>
</UserControl>
