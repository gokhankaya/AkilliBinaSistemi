<Window x:Class="GUI_Simulation.LCS.mainWindowLCS"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI_Simulation.LCS"
        mc:Ignorable="d"
        Title="Sequences" Height="600" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="345"></ColumnDefinition>
            <ColumnDefinition Width="300"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.RowSpan="2" Grid.Column="0" Grid.Row="1" Margin="2">
            <StackPanel Name="pnlControlContainer" Background="Gray" Orientation="Vertical"/>
        </ScrollViewer>
        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
            <Button Margin="2" Content="Yeni Kişi Ekle" Name="btnAddNewPersonController" Click="btnAddNewPersonController_Click"></Button>
        </StackPanel>

        <Border Grid.Row="2" Grid.Column="1" BorderThickness="1" BorderBrush="Black">
            <Grid Margin="5"  >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Label Grid.Row="0">Loglar</Label>
                <ScrollViewer Grid.Row="1" >
                    <StackPanel Orientation="Vertical" Name="pnlLogs"></StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Margin="2" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2" >

            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0">
                <Label Grid.Column="0" Content="Senaryo Sayısı:" Margin="5,0,2,0"></Label>
                <TextBox VerticalContentAlignment="Center" Grid.Column="1" Text="{Binding scerioCount}" Margin="0,0,5,0" Width="125"></TextBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" >
                <Button Width="75" Margin="2" Content="Başla" Grid.Column="3" Name="btnRun" Click="btnRun_Click" ></Button>
                <Button Width="75" Margin="2" Content="Diziyi Göster" Name="btnShowTotalSequence" Click="btnShowTotalSequence_Click" ></Button>
                <Button Margin="2" Content="Çizelgeleri Yönet" Name="btnGraphSettings" Click="btnGraphSettings_Click"></Button>
            </StackPanel>

        </Grid>
        <Border Grid.Column="2" Grid.Row="2" BorderThickness="1" BorderBrush="Black">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Label Grid.Row="0">Sonuçlar</Label>
                <ScrollViewer Grid.Row="1">
                    <TextBlock  TextWrapping="Wrap" Text="{Binding TestResult}"></TextBlock>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
