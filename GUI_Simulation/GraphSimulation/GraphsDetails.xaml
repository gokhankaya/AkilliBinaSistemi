<Window x:Class="GUI_Simulation.GraphsDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI_Simulation"
        mc:Ignorable="d"
        Title="Çizelge Detayı" Height="400" Width="700" WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow" ResizeMode="CanResizeWithGrip">
    <Grid Margin="3" x:Name="Container">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="3*"></ColumnDefinition>
            <ColumnDefinition Width="2*"></ColumnDefinition>
            <ColumnDefinition Width="3*"></ColumnDefinition>
            <ColumnDefinition Width="3*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock VerticalAlignment="Center" Grid.Column="0" Grid.Row="1" Text="Düğüm (Node)" TextWrapping="Wrap"></TextBlock>
        <Label Grid.Column="1" Grid.Row="1" VerticalAlignment="Top" VerticalContentAlignment="Top" Content=":"></Label>

        <TextBlock VerticalAlignment="Center" Grid.Column="0" Grid.Row="2" Text="Cihaz Bilgisi" TextWrapping="Wrap"></TextBlock>
        <Label Grid.Column="1" Grid.Row="2" VerticalAlignment="Top" VerticalContentAlignment="Top" Content=":"></Label>

        <TextBlock VerticalAlignment="Center" Grid.Column="0" Grid.Row="3" Text="Kenar (Edge)" TextWrapping="Wrap"></TextBlock>
        <Label Grid.Column="1" Grid.Row="3" Content=":"/>

        <TextBlock Margin="3,0" Grid.Column="4" Grid.Row="0" Text="Düğümler" TextWrapping="Wrap"/>
        <TextBlock Grid.Column="5" Grid.Row="0" Text="Kenarlar" TextWrapping="Wrap"/>


        <StackPanel Background="WhiteSmoke" Margin="0,5" Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="3" Grid.RowSpan="2">
            <TextBlock Margin="0,10,0,0" Text="Çizelge Detayları:"/>
            <TextBlock Margin="3" Text="Çizelgenin adı:"/>
            <TextBlock Margin="5,0" Text="{Binding GraphName}"/>
            <TextBlock Margin="3" Text="Toplam düğüm sayısı:"/>
            <TextBlock Margin="5,0" Text="{Binding ElementName=lsbNodes, Path=Items.Count}"/>
            <TextBlock Margin="3" Text="Toplam kenar sayısı:"/>
            <TextBlock Margin="5,0" Text="{Binding ElementName=lsbEdges, Path=Items.Count}"/>
        </StackPanel>
        <TextBox VerticalContentAlignment="Center" Grid.Column="2" Grid.Row="1" Margin="1"  Text="{Binding NodeName}"></TextBox>
        <ComboBox VerticalContentAlignment="Center" Grid.Column="2" Grid.Row="2" Margin="1" x:Name="cmbItems"></ComboBox>
        <Button x:Name="btnAddNode" Margin="5,2" Content="Ekle" Click="btnAddNode_Click" Grid.Column="3" Grid.Row="1" ></Button>
        <Button x:Name="btnAddEdge" Margin="5,2" Content="Ekle" Click="btnAddEdge_Click" Grid.Column="3" Grid.Row="3"></Button>
        <Button x:Name="btnShowGraph" Margin="5,2" Content="Göster" Click="btnShowGraph_Click" Grid.Column="3" Grid.Row="4"></Button>
        <Button x:Name="btnUpdate" Margin="5,2" Content="Güncelle" Click="btnUpdate_Click" Grid.Column="3" Grid.Row="5"></Button>
        <StackPanel Grid.Column="3" Grid.Row="6">
            <Button x:Name="btnRemoveWithOutWieght" Margin="5,2" Content="Ağırlıksızları sil" Click="btnRemoveWithOutWieght_Click" Grid.Column="3" Grid.Row="5"></Button>
        </StackPanel>
        <ListBox Margin="3,3,3,5" x:Name="lsbNodes" Grid.Column="4" Grid.Row="3" Grid.RowSpan="5" SelectionChanged="lsbNodes_SelectionChanged"></ListBox>
        <ListBox Margin="3,3,3,5" x:Name="lsbEdges" Grid.Column="5" Grid.Row="3" Grid.RowSpan="5"></ListBox>
        <TextBlock VerticalAlignment="Center" Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="3" Text="Çizelgeyi görsel olarak göster:" TextWrapping="Wrap"></TextBlock>
        <Button x:Name="btnRemoveNode" Margin="5,2" Content="Kaldır" Grid.Column="4" Grid.Row="1" Click="btnRemoveNode_Click"></Button>
        <Button x:Name="btnRemoveEdge" Margin="5,2" Content="Kaldır" Grid.Column="5" Grid.Row="1" Click="btnRemoveEdge_Click"></Button>

        <TextBox Grid.Row="2" Grid.Column="4" Margin="2"  Name="txtNodeFilter" TextChanged="txtNodeFilter_TextChanged"></TextBox>
        <TextBox Grid.Row="2" Grid.Column="5" Margin="2"  Name="txtEdgeFilter" TextChanged="txtEdgeFilter_TextChanged"></TextBox>
    </Grid>
</Window>
