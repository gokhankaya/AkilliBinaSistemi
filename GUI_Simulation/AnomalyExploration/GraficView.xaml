<Window x:Class="GUI_Simulation.AnomalyExploration.GraficView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI_Simulation.AnomalyExploration"
        mc:Ignorable="d"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:zed="clr-namespace:ZedGraph;assembly=ZedGraph"
        Title="GraficView" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Margin="5" Orientation="Horizontal">
            <Label>Perplexity:</Label>
            <TextBox x:Name="txtPerplexityValue" VerticalContentAlignment="Center"  Width="150" Height="25"  VerticalAlignment="Center"/>
            <Button Width="85" Height="25"  x:Name="btnReflesh" Content="Yenile" Click="btnReflesh_Click" Margin="10,0,0,0"/>
        </StackPanel>

        <WindowsFormsHost Grid.Row="1" Name="windowsFormsHost1" Margin="5">
            <zed:ZedGraphControl x:Name="zgc" Width="500" Height="320" />
        </WindowsFormsHost>
    </Grid>
</Window>
