<Window x:Class="GUI_Simulation.SequencePattern.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI_Simulation.SequencePattern"
        mc:Ignorable="d"
        Title="ADLE Ayarlar" Height="325" Width="150" WindowStyle="None" ResizeMode="NoResize"  Closing="Window_Closing" WindowStartupLocation="CenterScreen" Background="Black">
    <Grid Grid.Column="1" Margin="2" Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>


        <Button  Margin="10,2,10,0" Grid.Row="0" Content="X" Name="btnClose" HorizontalAlignment='Right' VerticalAlignment="Top" Width="15" Click='btnClose_Click' />
        <GroupBox Grid.Row="1" Header="Senaryo Sayısı" BorderThickness="0" Margin="5,0">
            <TextBox Text="{Binding ScenarioCount}" Margin="1"></TextBox>
        </GroupBox>
        <GroupBox Grid.Row="2" Header="LCS Eşik Değeri" BorderThickness="0" Margin="5,5,5,0">
            <TextBox Text="{Binding LCSThreshold}" Margin="1"></TextBox>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Eğitim Versini Kullan" BorderThickness="0" Margin="5,0">
            <CheckBox VerticalAlignment="Center" Margin="5,0" IsChecked="{Binding UseTrainingSet}"></CheckBox>
        </GroupBox>

        <GroupBox Visibility="Collapsed" Grid.Row="4" Header="Softmax" BorderThickness="0" Margin="5,0">
            <CheckBox VerticalAlignment="Center" Margin="5,0" IsChecked="{Binding UseSoftmax}"></CheckBox>
        </GroupBox>

        <GroupBox Visibility="Collapsed" Grid.Row="5" Header="Min-max / Softmax" BorderThickness="0" Margin="5,0">
            <CheckBox VerticalAlignment="Center" Margin="5,0" IsChecked="{Binding UseMinmaxSoftmax}"></CheckBox>
        </GroupBox>

        <GroupBox Visibility="Collapsed" Grid.Row="6" Header="Z-Score / Softmax" BorderThickness="0" Margin="5,0">
            <CheckBox VerticalAlignment="Center" Margin="5,0" IsChecked="{Binding UseZscoreSoftmax}"></CheckBox>
        </GroupBox>

        <GroupBox Visibility="Collapsed" Grid.Row="7" Header="Seçerken Karıştır" BorderThickness="0" Margin="5,0">
            <CheckBox VerticalAlignment="Center" Margin="5,0" IsChecked="{Binding RandomSelection}"></CheckBox>
        </GroupBox>

    </Grid>
</Window>
