<UserControl x:Class="GUI_Simulation.SequencePattern.PersonResultBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GUI_Simulation.SequencePattern"
             mc:Ignorable="d" 
           Width="400" Margin="2"
             d:DesignHeight="30" d:DesignWidth="300">
    <Border BorderThickness="1" BorderBrush="WhiteSmoke">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>

            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Orientation="Horizontal" Margin="2">
                <TextBlock  Text="{Binding Order}"  />
                <TextBlock Text=" )"/>
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Orientation="Horizontal" Margin="2">
                <TextBlock Text="( "/>
                <TextBlock  Text="{Binding SequenceOrder}" />
                <TextBlock Text=" )"/>
            </StackPanel>

            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding SequenceString}" Grid.Column="2" TextWrapping="Wrap" Margin="2"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right"  Margin="2" Grid.Column="3"  >
                <TextBlock Text="( "/>
                <TextBlock Text="{Binding SequenceLength}" TextWrapping="NoWrap"/>
                <TextBlock Text=" )"/>
            </StackPanel>

            <Grid Grid.Column="4"  Margin="2" HorizontalAlignment="Right" VerticalAlignment="Center" >
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2">
                    <TextBlock Text="B: "></TextBlock>
                    <TextBlock Text="{Binding ExpectedPersonValue}" TextWrapping="Wrap" ></TextBlock>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="2" >
                    <TextBlock Text="G: "></TextBlock>
                    <TextBlock Text="{Binding PersonValue}" TextWrapping="Wrap" ></TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
