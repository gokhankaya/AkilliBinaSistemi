<Window x:Class="GUI_Simulation.SimulationPortal.PortalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI_Simulation.SimulationPortal"
        mc:Ignorable="d"
        Title="ADLE Simülasyon" WindowState="Normal" ShowInTaskbar="False"  WindowStyle="ToolWindow" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Height="300" Width="220"  >
    <Grid>
    <ScrollViewer Margin="5" BorderThickness="1" BorderBrush="Black" >
        <StackPanel Name="container" Orientation="Vertical">
            <Button Click="btnRulesBased_Click"  Name="btnRulesBased" Content="Veri tabanı İşlemleri" Margin="15,5" Height="30"></Button>
            <Button Click="btnGraphs_Click"  Name="btnGraphs" Content="Çizge" Margin="15,5" Height="30"></Button>
            <Button Click="btnAnomality1_Click"  Name="btnAnomality1" Content="Anomalite Tespiti (tek)" Margin="15,5" Height="30"></Button>
            <Button Click="btnAnomality2_Click"  Name="btnAnomality2" Content="Anomalite Tespiti (çoklu)" Margin="15,5" Height="30"></Button>
            <Button Click="btnSequencePatternLCS_Click" Name="btnSequencePatternLCS" Content="Sıralı Dizi (LCS)" Margin="15,5" Height="30"></Button>
                <Button Click="btnSequencePattern_Click" Name="btnSequencePattern" Content="Sıralı Dizi" Margin="15,5" Height="30"></Button>

            </StackPanel>
    </ScrollViewer>
    </Grid>
</Window>
